# Keep the build context small and the image clean. Only the package metadata,
# src/, scripts/, workflow/, and config/ are needed to build/run the image.

# Version control & CI
.git
.github
.gitignore
.gitattributes
.editorconfig
.pre-commit-config.yaml

# Local data (never shipped in the image) and generated output
data
results
site

# Docs and tests are not needed at runtime
docs
tests
mkdocs.yml

# Python / tooling caches and build artefacts
__pycache__
*.pyc
*.pyo
.pytest_cache
.ruff_cache
.mypy_cache
*.egg-info
build
dist
.venv
venv

# Conda env file (the image installs via pip)
environment.yml
